# Copy to .env and fill in. The serve task auto-loads .env.
OPENAI_API_KEY=sk-your-key-here

# Which provider: "openai" (default) or "featherless"
LLM_PROVIDER=openai

# Model. openai → gpt-4o-mini / gpt-4o. featherless → e.g. Qwen/Qwen2.5-72B-Instruct
ATLAS_MODEL=gpt-4o-mini

# Only needed when LLM_PROVIDER=featherless
FEATHERLESS_API_KEY=

# Optional: only needed to use LIVE Supabase data instead of the built-in
# seed.ts fallback. Leave blank for the demo — it works without a database.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
