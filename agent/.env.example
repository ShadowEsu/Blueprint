# Copy to .env and fill in. The serve task auto-loads .env.
OPENAI_API_KEY=sk-your-key-here

# Which provider: "openai" (default) or "featherless"
LLM_PROVIDER=openai

# Model. openai → gpt-4o-mini / gpt-4o. featherless → e.g. Qwen/Qwen2.5-72B-Instruct
ATLAS_MODEL=gpt-4o-mini

# Only needed when LLM_PROVIDER=featherless
FEATHERLESS_API_KEY=

# Blueprint-main Supabase project. Prefer the publishable/anon key for this
# read-only RLS schema. The service-role key is supported for server deployments
# but should never be shipped to a browser or mobile client.
SUPABASE_URL=
# Current Supabase projects expose a publishable key. Legacy projects can use
# SUPABASE_ANON_KEY instead.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
